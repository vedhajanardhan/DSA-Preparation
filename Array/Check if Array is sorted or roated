// Problem: Check if Array is Sorted and Rotated
// Platform: LeetCode (1752)
// Approach: Count number of breaks in order
// Time Complexity: O(n)
// Space Complexity: O(1)

class CheckSortedAndRotated {

    public static void main(String[] args) {

        int[] nums = {3,4,5,1,2};

        boolean result = check(nums);

        System.out.println(result);
    }

    public static boolean check(int[] nums) {

        int count = 0;
        int n = nums.length;

        for(int i = 0; i < n; i++) {

            // compare current with next (circular)
            if(nums[i] > nums[(i + 1) % n]) {
                count++;
            }
        }

        // valid if at most 1 break
        return count <= 1;
    }
}
