// Problem: Group Anagrams (LeetCode 49)
// Group strings that are anagrams of each other
// Approach: Character Frequency Count + HashMap
// Time Complexity: O(n * k)  (n = number of strings, k = max length of string)
// Space Complexity: O(n)

import java.util.*;

class GroupAnagrams {

    public static void main(String[] args) {

        String[] input = {"eat", "tea", "tan", "ate", "nat", "bat"};

        List<List<String>> result = groupAnagrams(input);

        System.out.println("Grouped Anagrams:");
        for (List<String> group : result) {
            System.out.println(group);
        }
    }

    public static List<List<String>> groupAnagrams(String[] strs) {

        // Map to store grouped anagrams
        Map<String, List<String>> map = new HashMap<>();

        for (String word : strs) {

            // Step 1: Create frequency array
            int[] count = new int[26];

            for (char c : word.toCharArray()) {
                count[c - 'a']++;
            }

            // Step 2: Convert array to string key
            String key = Arrays.toString(count);

            // Step 3: Add word to corresponding group
            map.putIfAbsent(key, new ArrayList<>());
            map.get(key).add(word);
        }

        // Step 4: Return grouped values
        return new ArrayList<>(map.values());
    }
}
